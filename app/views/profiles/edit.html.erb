<div class="container mt-4 mb-5">
  <div class="row justify-content-center">
    <div class="col-lg-6">
      <div class="card shadow-sm border-0">
        <div class="card-body p-4">
          <h1 class="h4 mb-4">Profili Düzenle</h1>

          <% if current_user.errors.any? %>
            <div class="alert alert-danger py-2">
              <ul class="mb-0 ps-3">
                <% current_user.errors.full_messages.each do |message| %>
                  <li><%= message %></li>
                <% end %>
              </ul>
            </div>
          <% end %>

          <%= form_with model: current_user, url: profile_path, method: :patch do |form| %>
            <div class="mb-3">
              <label class="form-label">İsim</label>
              <%= form.text_field :name, class: "form-control", placeholder: "Adınız Soyadınız" %>
            </div>

            <div class="mb-3">
              <label class="form-label">E-posta</label>
              <%= form.email_field :email_address, class: "form-control" %>
            </div>

            <%= form.submit "Kaydet", class: "btn btn-warning w-100 fw-semibold" %>
          <% end %>

          <div class="text-center mt-3">
            <%= link_to "Şifrenizi mi değiştirmek istiyorsunuz?", new_password_path, class: "small text-decoration-none" %>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
