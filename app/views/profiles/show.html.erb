<div class="container mt-4 mb-5">
  <% if flash[:notice] %>
    <div class="alert alert-success py-2"><%= flash[:notice] %></div>
  <% end %>

  <div class="mb-4">
    <h1 class="h4 mb-1">Merhaba, <%= current_user.name.presence || "Kullanıcı" %></h1>
    <p class="text-muted mb-0">Panelinden eklediğin istasyonları yönetebilirsin.</p>
  </div>

  <div class="row g-3 mb-4">
    <div class="col-sm-6">
      <div class="card h-100">
        <div class="card-body">
          <div class="stat-tile-label">Eklediğim istasyon</div>
          <div class="stat-tile-value"><%= @stations.size %></div>
        </div>
      </div>
    </div>
    <div class="col-sm-6">
      <div class="card h-100">
        <div class="card-body">
          <div class="stat-tile-label">Favori sayım</div>
          <div class="stat-tile-value"><%= @favorites.size %></div>
        </div>
      </div>
    </div>
  </div>

  <div class="card shadow-sm border-0 mb-4">
    <div class="card-body p-4">
      <div class="d-flex justify-content-between align-items-start">
        <div>
          <h2 class="text-muted text-uppercase small mb-1">Hesap Bilgileri</h2>
          <p class="mb-0"><strong><%= current_user.name.presence || "İsimsiz Kullanıcı" %></strong> · <%= current_user.email_address %></p>
          <p class="text-muted small mb-0 mt-2">Üye olma tarihi: <%= current_user.created_at.strftime("%d.%m.%Y") %></p>
        </div>
        <%= link_to "Profili Düzenle", edit_profile_path, class: "btn btn-outline-secondary btn-sm" %>
      </div>
    </div>
  </div>

  <div class="d-flex justify-content-between align-items-center mb-3">
    <div>
      <h2 class="h5 mb-0">Eklediğim İstasyonlar</h2>
      <p class="text-muted small mb-0">Toplam <%= @total_connectors %> konnektör</p>
    </div>
    <%= link_to "Yeni İstasyon Ekle", new_station_path, class: "btn btn-warning btn-sm fw-semibold" %>
  </div>

  <% if @stations.any? %>
    <ul class="list-group shadow-sm">
      <% @stations.each do |station| %>
        <li class="list-group-item d-flex justify-content-between align-items-center">
          <div>
            <h6 class="mb-1"><%= link_to station.title, "/stations/local-#{station.id}" %></h6>
            <p class="mb-0 text-muted small"><%= [ station.address_line, station.district, station.province ].select(&:present?).join(", ") %></p>
          </div>
          <div class="d-flex gap-2">
            <%= link_to "Düzenle", edit_station_path(station), class: "btn btn-outline-secondary btn-sm" %>
            <%= button_to "Sil", station_path(station), method: :delete, class: "btn btn-outline-danger btn-sm", form: { data: { turbo_confirm: "Bu istasyonu silmek istediğinize emin misiniz?" } } %>
          </div>
        </li>
      <% end %>
    </ul>
  <% else %>
    <div class="alert alert-info">
      Henüz istasyon eklemediniz. <%= link_to "İlk istasyonunu ekle", new_station_path %>.
    </div>
  <% end %>

  <h2 class="h5 mb-3 mt-4">Favorilerim</h2>

  <% if @favorites.any? %>
    <ul class="list-group shadow-sm">
      <% @favorites.each do |favorite| %>
        <li class="list-group-item d-flex justify-content-between align-items-center">
          <%= link_to favorite.station_title, "/stations/#{favorite.station_identifier}" %>
          <%= button_to "Kaldır", favorite_path(favorite), method: :delete, class: "btn btn-outline-danger btn-sm", form: { data: { turbo_confirm: "Favorilerden kaldırılsın mı?" } } %>
        </li>
      <% end %>
    </ul>
  <% else %>
    <div class="alert alert-info">
      Henüz favori istasyonunuz yok.
    </div>
  <% end %>
</div>
