<div class="stations-hero">
  <div class="container text-center">
    <h1 class="mb-2">Türkiye'nin En Güncel Şarj İstasyonu Haritası ⚡️</h1>
    <p class="mb-3">Yolculuğa ara vermeyin. Çevrenizdeki en yakın ve uygun şarj noktalarını anında bulun.</p>
    <div class="d-flex justify-content-center align-items-center gap-3 flex-wrap">
      <div class="view-toggle">
        <span class="view-toggle-link active">🗺️ Harita</span>
        <%= link_to "📋 Liste", stations_path, class: "view-toggle-link" %>
      </div>
      <span class="hero-live-count">
        <span class="pulse-icon"></span>
        Türkiye genelinde <strong><%= @stations_count %></strong> aktif istasyon güncel olarak listeleniyor!
      </span>
    </div>
  </div>
</div>

<main class="search-section">
  <div class="container mt-4 mb-5" data-controller="map_toggle">
    <div class="d-lg-none mb-3 text-center">
      <button class="btn btn-outline-primary me-2" data-action="click->map_toggle#showList">Liste</button>
      <button class="btn btn-outline-primary" data-action="click->map_toggle#showMap">Harita</button>
    </div>

    <div class="map-filter-panel p-3 p-md-4">
    <div class="row align-items-stretch">
      <div class="col-lg-4 mb-4" data-map_toggle-target="list">
        <div class="filter-sidebar">
            <%= form_with url: "/search", method: :get, local: true, data: { controller: "location-filter" } do %>
              <div class="accordion mb-3" id="filterAccordion">
                <div class="accordion-item">
                  <h2 class="accordion-header">
                    <button class="accordion-button" type="button" data-bs-toggle="collapse" data-bs-target="#filterDistance">
                      📏 Mesafe Filtresi
                    </button>
                  </h2>
                  <div id="filterDistance" class="accordion-collapse collapse show" data-bs-parent="#filterAccordion">
                    <div class="accordion-body">
                      <p class="mb-2">Mesafe: <span id="distance-value"><%= params[:distance].presence || 10 %></span> km</p>
                      <input type="range" name="distance" class="form-range" id="distance-slider" min="1" max="50" value="<%= params[:distance].presence || 10 %>" onchange="this.form.requestSubmit()">
                    </div>
                  </div>
                </div>

                <div class="accordion-item">
                  <h2 class="accordion-header">
                    <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#filterProvince">
                      📍 İl Filtresi
                    </button>
                  </h2>
                  <div id="filterProvince" class="accordion-collapse collapse" data-bs-parent="#filterAccordion">
                    <div class="accordion-body">
                      <select name="il" class="form-select" data-location-filter-target="province" data-action="change->location-filter#updateDistricts">
                        <option value="">İl seçin</option>
                        <% @provinces.each do |il| %>
                          <option value="<%= il %>" <%= "selected" if il == params[:il] %>><%= il %></option>
                        <% end %>
                      </select>
                    </div>
                  </div>
                </div>

                <div class="accordion-item">
                  <h2 class="accordion-header">
                    <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#filterDistrict">
                      🏘️ İlçe Filtresi
                    </button>
                  </h2>
                  <div id="filterDistrict" class="accordion-collapse collapse" data-bs-parent="#filterAccordion">
                    <div class="accordion-body">
                      <select name="ilce" class="form-select" data-location-filter-target="district" onchange="this.form.requestSubmit()">
                        <% if params[:il].present? %>
                          <% (TurkeyLocationService.districts_for(params[:il]) || []).each do |ilce| %>
                            <option value="<%= ilce %>" <%= "selected" if ilce == params[:ilce] %>><%= ilce %></option>
                          <% end %>
                        <% else %>
                          <option value="">Önce il seçin</option>
                        <% end %>
                      </select>
                    </div>
                  </div>
                </div>
              </div>

              <div class="d-flex gap-2 mb-3">
                <button type="submit" class="btn btn-primary flex-fill">Filtrele</button>
                <%= link_to "Temizle", root_path, class: "btn btn-outline-secondary flex-fill" %>
              </div>
    <% end %>

      <div id="no-stations-message" class="alert alert-warning d-none">
        Bu filtrede istasyon bulunamadı.
      </div>
        </div>
      </div>

      <div class="col-lg-8 mb-4 d-none d-lg-block" data-map_toggle-target="map">
        <div class="d-flex justify-content-end mb-2">
          <span class="text-muted small">Haritada gösterilen: <strong id="visible-station-count">0</strong> istasyon</span>
        </div>
        <div class="card shadow-sm h-100">
          <div class="card-body p-0 position-relative">
            <div id="map" class="split-map rounded"></div>

            <div class="position-absolute bottom-0 end-0 m-3 bg-white rounded shadow-sm p-2" style="z-index: 1000;">
              <div class="d-flex align-items-center mb-1">
                <span class="station-marker station-marker-ocm me-2 d-inline-block"></span>
                <small>OCM İstasyonu</small>
              </div>
              <div class="d-flex align-items-center">
                <span class="station-marker station-marker-local me-2 d-inline-block"></span>
                <small>Kullanıcı Eklemesi</small>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
    </div>
  </div>

  <%= render "shared/station_detail_panel" %>

  <script type="module">
      import { initStationDetailPanel } from "station_detail_panel";
      import { createStationLayer } from "station_markers";
      var showStationDetail = initStationDetailPanel();

          var stations = <%= (@stations || []).to_json.html_safe %>;
          var hasLocationFilter = <%= (@location_filtered || false).to_json %>;
          window.turkeyDistricts = <%= TURKEY_PROVINCES_DATA.to_json.html_safe %>;
          window.vehicleBrandsData = <%= VEHICLE_BRANDS_DATA.to_json.html_safe %>;
      var map = L.map("map");
      map.fitBounds([[35.8, 25.6], [42.1, 44.8]]);
      L.tileLayer("https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png").addTo(map);

      var stationLayer = createStationLayer(map);

      function drawMarkers(maxDistance) {
        // Bir il/ilçe filtresi uygulanmamışsa tüm istasyonları göster;
        // uygulanmışsa sadece seçilen mesafeye uyanları göster
        var filtered = stations.filter(function(station) {
          if (!hasLocationFilter) return true;
          var distance = station.AddressInfo.Distance;
          return distance == null || distance <= maxDistance;
        });

        stationLayer.render(filtered, showStationDetail, "visible-station-count");

        // Sadece bir il/ilçe filtresi uygulanmışsa ve sonuç boşsa uyarı mesajını göster
        var noStationsMessage = document.getElementById("no-stations-message");
        if (noStationsMessage) {
          noStationsMessage.classList.toggle("d-none", !hasLocationFilter || filtered.length > 0);
        }
      }

      // İlk yüklemede, slider'ın başlangıç değeriyle çiz
      var slider = document.getElementById("distance-slider");
      var valueLabel = document.getElementById("distance-value");

      if (slider) {
        drawMarkers(parseInt(slider.value));

        slider.addEventListener("input", function() {
          valueLabel.textContent = slider.value;
          drawMarkers(parseInt(slider.value));
        });
      }
    </script>
</main>