<!DOCTYPE html>
<html>

  <head>

    <title><%= content_for(:title) || "Open Charge Map" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Open Charge Map">
    <meta name="mobile-web-app-capable" content="yes">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    <link rel="stylesheet" href="https://unpkg.com/leaflet.markercluster@1.5.3/dist/MarkerCluster.css" />
    <link rel="stylesheet" href="https://unpkg.com/leaflet.markercluster@1.5.3/dist/MarkerCluster.Default.css" />
    <script src="https://unpkg.com/leaflet.markercluster@1.5.3/dist/leaflet.markercluster.js"></script>

    <%# Bootstrap'ın JavaScript'i application.js içinde importmap ile ("import "bootstrap"") yükleniyor -
        buraya ayrıca klasik <script> ile eklenirse iki kopya birden data-bs-toggle olaylarını dinler ve
        aç/kapa gibi davranışlar bir tıklamada açılıp anında kapanır. %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
      <div class="container-fluid">
        <%= link_to root_path, class: "navbar-brand d-flex align-items-center" do %>
          <%= image_tag "logo.svg", alt: "Şarj Haritası logosu", width: 28, height: 28, class: "me-2" %>
          Şarj Haritası
        <% end %>

        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarContent">
          <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse" id="navbarContent">
          <ul class="navbar-nav ms-auto align-items-lg-center">
            <li class="nav-item"><%= link_to "Anasayfa", root_path, class: "nav-link" %></li>
            <li class="nav-item"><%= link_to "Hakkımızda", about_path, class: "nav-link" %></li>
            <li class="nav-item"><%= link_to "Şarj İstasyonları", map_path, class: "nav-link" %></li>
            <li class="nav-item"><%= link_to "Bize Ulaşın", contact_path, class: "nav-link" %></li>
            <% if authenticated? %>
              <li class="nav-item dropdown ms-lg-3">
                <a class="btn btn-warning rounded-pill fw-semibold dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                  <%= current_user.name.presence || "Hesabım" %>
                </a>
                <ul class="dropdown-menu dropdown-menu-end">
                  <li><%= link_to "Profilim", profile_path, class: "dropdown-item" %></li>
                  <li><%= link_to "İstasyon Ekle", new_station_path, class: "dropdown-item" %></li>
                  <li><hr class="dropdown-divider"></li>
                  <li><%= button_to "Çıkış Yap", session_path, method: :delete, class: "dropdown-item", form_class: "m-0" %></li>
                </ul>
              </li>
            <% else %>
              <li class="nav-item ms-lg-3">
                <%= link_to "Üye Girişi", new_session_path, class: "btn btn-warning rounded-pill fw-semibold" %>
              </li>
            <% end %>
          </ul>
        </div>
      </div>
    </nav>

    <div class="container">
      <%= yield %>
    </div>

    <footer class="site-footer">
      <div class="container py-5">
        <div class="row gy-4">
          <div class="col-md-3">
            <div class="d-flex align-items-center mb-2">
              <%= image_tag "logo.svg", alt: "Şarj Haritası logosu", width: 32, height: 32, class: "me-2" %>
              <span class="fw-bold fs-5">Şarj Haritası</span>
            </div>
            <p class="text-white-50 small mb-0">Türkiye'nin elektrikli araç şarj istasyonu haritası. Güncel konumlar, kesintisiz yolculuklar.</p>
          </div>

          <div class="col-md-3">
            <h6 class="text-uppercase small fw-bold mb-3">Sayfalar</h6>
            <ul class="list-unstyled footer-links">
              <li><%= link_to "Anasayfa", root_path %></li>
              <li><%= link_to "Hakkımızda", about_path %></li>
              <li><%= link_to "Şarj İstasyonları", map_path %></li>
              <li><%= link_to "Bize Ulaşın", contact_path %></li>
            </ul>
          </div>

          <div class="col-md-3">
            <h6 class="text-uppercase small fw-bold mb-3">Yasal</h6>
            <ul class="list-unstyled footer-links">
              <li><%= link_to "Hizmet Şartları", terms_path %></li>
              <li><%= link_to "Gizlilik ve Hizmet Sözleşmesi", privacy_path %></li>
              <li><%= link_to "KVKK", kvkk_path %></li>
              <li><%= link_to "Çerez Politikası", cookies_path %></li>
              <li>
                <button type="button" class="btn btn-link p-0 footer-link-button" data-bs-toggle="modal" data-bs-target="#cookiePreferencesModal">
                  Çerez Tercihlerimi Yönet
                </button>
              </li>
            </ul>
          </div>

          <div class="col-md-3">
            <h6 class="text-uppercase small fw-bold mb-3">İletişim</h6>
            <ul class="list-unstyled small text-white-50">
              <li class="mb-2">📧 destek@sarjharitasi.com</li>
              <li class="mb-2">📞 +90 (850) 123 45 67</li>
              <li>📍 İstanbul, Türkiye</li>
            </ul>
          </div>
        </div>

        <hr class="border-secondary my-4">

        <p class="text-center text-white-50 small mb-0">&copy; <%= Time.current.year %> Şarj Haritası. Tüm Hakları Saklıdır.</p>
      </div>
    </footer>

    <%= render "shared/cookie_preferences_modal" %>
  </body>
</html>