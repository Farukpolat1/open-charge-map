<div class="row justify-content-center my-5">
  <div class="col-11 col-sm-8 col-md-6 col-lg-5">
    <div class="card shadow-sm border-0">
      <div class="card-body p-4">
        <h1 class="h4 mb-4">Şifrenizi mi unuttunuz?</h1>

        <% if flash[:alert] %>
          <div class="alert alert-danger py-2"><%= flash[:alert] %></div>
        <% end %>
        <% if flash[:notice] %>
          <div class="alert alert-success py-2"><%= flash[:notice] %></div>
        <% end %>

        <%= form_with url: passwords_path do |form| %>
          <div class="mb-3">
            <label class="form-label">E-posta</label>
            <%= form.email_field :email_address, required: true, autofocus: true, autocomplete: "username", class: "form-control", placeholder: "ornek@mail.com", value: params[:email_address] %>
          </div>

          <%= form.submit "E-posta Sıfırlama Talimatları Gönder", class: "btn btn-warning w-100 fw-semibold" %>
        <% end %>

        <div class="text-center mt-3">
          <%= link_to "Girişe dön", new_session_path, class: "small text-decoration-none" %>
        </div>
      </div>
    </div>
  </div>
</div>
