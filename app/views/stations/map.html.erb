<div class="container-fluid mt-4 mb-5" data-controller="map_toggle">
  <div class="mb-4">
    <h1 class="mb-1">Şarj İstasyonları Haritası</h1>
    <p class="text-muted mb-0">Türkiye genelindeki tüm şarj istasyonlarını haritada keşfedin.</p>
  </div>

  <div class="d-lg-none mb-3">
    <button class="btn btn-outline-primary me-2" data-action="click->map_toggle#showList">Liste</button>
    <button class="btn btn-outline-primary" data-action="click->map_toggle#showMap">Harita</button>
  </div>

  <div class="map-filter-panel p-3 p-md-4">
  <div class="row align-items-stretch">
    <div class="col-lg-5 mb-4" data-map_toggle-target="list">
      <%= form_with url: "/search", method: :get, local: true, class: "mb-3" do %>
        <%= hidden_field_tag :view, "map" %>
        <div class="input-group">
          <span class="input-group-text bg-white">🔍</span>
          <input type="text" name="location" id="station-search" value="<%= params[:location] %>" class="form-control" placeholder="İl veya istasyon adı ile arayın...">
          <button type="submit" class="btn btn-primary">Ara</button>
        </div>
      <% end %>

      <div class="card shadow-sm h-100">
        <div class="card-body station-list-panel">
          <ul class="list-group list-group-flush" id="station-list">
            <% if @stations.present? %>
              <% @stations.each do |station| %>
                <% address = station["AddressInfo"] || {} %>
                <li class="list-group-item">
                  <h6 class="mb-1">
                    <span class="station-dot <%= station["ID"].to_s.start_with?("local-") ? "station-marker-local" : "station-marker-ocm" %> me-2"></span>
                    <%= link_to address["Title"], "/stations/#{station["ID"]}" %><%= station_status_badge(station) %>
                  </h6>
                  <p class="mb-1 text-muted small">
                    <%= address["AddressLine1"] %>, <%= address["Town"] %>, <%= address["StateOrProvince"] %>
                  </p>
                </li>
              <% end %>
            <% else %>
              <li class="list-group-item text-muted">Gösterilecek istasyon bulunamadı.</li>
            <% end %>
          </ul>
        </div>
      </div>
    </div>

    <div class="col-lg-7 mb-4 d-none d-lg-block" data-map_toggle-target="map">
      <div class="d-flex justify-content-end mb-2">
        <span class="text-muted small">Haritada gösterilen: <strong id="visible-station-count">0</strong> istasyon</span>
      </div>
      <div class="card shadow-sm h-100">
        <div class="card-body p-0 position-relative">
          <div id="map" class="split-map rounded"></div>

          <div class="position-absolute bottom-0 end-0 m-3 bg-white rounded shadow-sm p-2" style="z-index: 1000;">
            <div class="d-flex align-items-center mb-1">
              <span class="station-marker station-marker-ocm me-2 d-inline-block"></span>
              <small>OCM İstasyonu</small>
            </div>
            <div class="d-flex align-items-center">
              <span class="station-marker station-marker-local me-2 d-inline-block"></span>
              <small>Kullanıcı Eklemesi</small>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
  </div>

  <%= render "shared/station_detail_panel" %>
</div>

<script type="module">
  import { initStationDetailPanel } from "station_detail_panel";
  import { createStationLayer } from "station_markers";
  var showStationDetail = initStationDetailPanel();

  var stations = <%= (@stations || []).to_json.html_safe %>;
  var map = L.map("map");
  map.fitBounds([[35.8, 25.6], [42.1, 44.8]]);
  L.tileLayer("https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png").addTo(map);

  var stationLayer = createStationLayer(map);
  stationLayer.render(stations, showStationDetail, "visible-station-count");
</script>
