<div class="container mt-4 mb-5">
  <div class="row justify-content-center">
    <div class="col-lg-7">
      <div class="card shadow-sm border-0">
        <div class="card-body p-4">
          <% if @station.errors.any? %>
            <div class="alert alert-danger py-2">
              <ul class="mb-0 ps-3">
                <% @station.errors.full_messages.each do |message| %>
                  <li><%= message %></li>
                <% end %>
              </ul>
            </div>
          <% end %>

          <%= form_with model: @station do |form| %>
            <div class="mb-3">
              <label class="form-label">Başlık</label>
              <%= form.text_field :title, class: "form-control", placeholder: "İstasyon adı" %>
            </div>

            <div class="mb-3">
              <label class="form-label">Adres</label>
              <%= form.text_field :address_line, class: "form-control", placeholder: "Sokak, cadde vb." %>
            </div>

            <div class="row">
              <div class="col-md-6 mb-3">
                <label class="form-label">İlçe</label>
                <%= form.text_field :district, class: "form-control" %>
              </div>
              <div class="col-md-6 mb-3">
                <label class="form-label">İl</label>
                <%= form.text_field :province, class: "form-control" %>
              </div>
            </div>

            <div class="row">
              <div class="col-md-6 mb-3">
                <label class="form-label">Enlem (Latitude)</label>
                <%= form.number_field :latitude, step: "any", class: "form-control" %>
              </div>
              <div class="col-md-6 mb-3">
                <label class="form-label">Boylam (Longitude)</label>
                <%= form.number_field :longitude, step: "any", class: "form-control" %>
              </div>
            </div>

            <div class="row">
              <div class="col-md-6 mb-3">
                <label class="form-label">Konnektör Tipi</label>
                <%= form.text_field :connector_type, class: "form-control", placeholder: "Type 2, CCS, CHAdeMO..." %>
              </div>
              <div class="col-md-6 mb-3">
                <label class="form-label">Seviye</label>
                <%= form.text_field :level, class: "form-control" %>
              </div>
            </div>

            <div class="mb-3">
              <label class="form-label">Adet</label>
              <%= form.number_field :quantity, class: "form-control" %>
            </div>

            <div class="mb-3">
              <label class="form-label">Açıklama</label>
              <%= form.text_area :description, class: "form-control", rows: 3 %>
            </div>

            <%= form.submit (@station.persisted? ? "Güncelle" : "İstasyon Ekle"), class: "btn btn-warning w-100 fw-semibold" %>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>
