<div class="container mt-4 mb-5">
  <div class="row justify-content-center">
    <div class="col-lg-10">
      <div class="card shadow-sm border-0">
        <div class="card-body p-4">
          <%= link_to "← Araçlarım'a Dön", profile_path, class: "btn btn-outline-secondary btn-sm mb-3" %>

          <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-4">
            <h1 class="h4 mb-0"><%= @vehicle.brand %> <%= @vehicle.model %> — Şarj Geçmişi</h1>
            <% if @vehicle.charging_sessions.where(status: "active").none? %>
              <%= link_to "⚡ Yeni Şarj Başlat", new_vehicle_charging_session_path(@vehicle), class: "btn btn-warning fw-semibold" %>
            <% end %>
          </div>

          <div class="row g-3 mb-4">
            <div class="col-sm-4">
              <div class="charging-stat-tile">
                <div class="stat-tile-label">Toplam Oturum</div>
                <div class="stat-tile-value"><%= @charging_sessions.size %></div>
              </div>
            </div>
            <div class="col-sm-4">
              <div class="charging-stat-tile">
                <div class="stat-tile-label">Toplam Enerji</div>
                <div class="stat-tile-value"><%= number_with_precision(@total_kwh || 0, precision: 1) %> kWh</div>
              </div>
            </div>
            <div class="col-sm-4">
              <div class="charging-stat-tile charging-stat-tile-accent">
                <div class="stat-tile-label">Toplam Ödeme</div>
                <div class="stat-tile-value"><%= number_with_precision(@total_paid || 0, precision: 2) %> TL</div>
              </div>
            </div>
          </div>

          <% if @charging_sessions.any? %>
            <div class="table-responsive">
              <table class="table table-hover align-middle mb-0 charging-history-table">
                <thead>
                  <tr>
                    <th>İstasyon</th>
                    <th>Güç (kW)</th>
                    <th>Süre (dk)</th>
                    <th>Ödenen (TL)</th>
                    <th>Kullanılan (kWh)</th>
                    <th>Durum</th>
                    <th></th>
                  </tr>
                </thead>
                <tbody>
                  <% @charging_sessions.each do |session| %>
                    <tr>
                      <td><%= session.station_name %></td>
                      <td><%= session.power_kw %></td>
                      <td><%= session.duration_minutes %></td>
                      <td><%= session.amount_paid %></td>
                      <td><%= session.kwh_used %></td>
                      <td>
                        <% if session.status == "active" %>
                          <span class="badge bg-success-subtle text-success">● Aktif</span>
                        <% else %>
                          <span class="badge bg-secondary-subtle text-secondary">Tamamlandı</span>
                        <% end %>
                      </td>
                      <td>
                        <% if session.status == "active" %>
                          <%= link_to "Şarjı Bitir", edit_vehicle_charging_session_path(@vehicle, session), class: "btn btn-sm btn-primary" %>
                        <% else %>
                          <%= button_to "Sil", vehicle_charging_session_path(@vehicle, session), method: :delete, class: "btn btn-sm btn-outline-danger", form: { data: { turbo_confirm: "Bu kaydı silmek istediğinize emin misiniz?" } } %>
                        <% end %>
                      </td>
                    </tr>
                  <% end %>
                </tbody>
              </table>
            </div>
          <% else %>
            <div class="alert alert-info mb-0">Henüz şarj kaydı yok.</div>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>
