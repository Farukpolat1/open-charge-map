<h1>Şarja Başla</h1>
<%= form_with model: [@vehicle, @charging_session] do |form| %>
  <% if @charging_session.errors.any? %>
    <div class="alert alert-danger">
      <ul class="mb-0">
        <% @charging_session.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="mb-3">
    <%= form.label :station_name, "İstasyon Adı", class: "form-label" %>
    <%= form.text_field :station_name, required: true, autofocus: true, class: "form-control" %>
  </div>

  <div class="mb-3">
    <%= form.label :power_kw, "Güç (kW)", class: "form-label" %>
    <%= form.number_field :power_kw, required: true, step: "any", class: "form-control" %>
  </div>

  <%= form.submit "Oturum Aç", class: "btn btn-warning w-100 fw-semibold" %>
<% end %>