<div class="container mt-4 mb-5">
  <div class="row justify-content-center">
    <div class="col-lg-6">
      <div class="card shadow-sm border-0">
        <div class="card-body p-4">
          <h1 class="h4 mb-4">Araç Ekle</h1>

          <%= form_with model: @vehicle do |form| %>
            <%= render "form", form: form, vehicle: @vehicle %>
            <%= form.submit "Aracı Ekle", class: "btn btn-warning w-100 fw-semibold" %>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>
